# Lenticularis Configuration Template
# Copy this file to config.yml and adjust to your environment.
# When running via docker-compose the values below match the defaults.

# InfluxDB Configuration
influxdb:
  enabled: true
  url: "http://influxdb:8086"          # use "http://localhost:8086" outside Docker
  token: "dev-influxdb-token-change-in-prod"
  org: "lenticularis"
  bucket: "weather_data"
  timeout: 10000  # milliseconds

# Forecast Collectors
# Layered approach: short-horizon runs every 3 h for the next ~30 h (where fresh data matters),
# extended run once per day for the full 5-day window.
# Within the same calendar day (init_date), later writes overwrite earlier ones in InfluxDB,
# so the most recent model run always wins for any given valid_time.
forecast_collectors:
  - name: "open-meteo-short"
    enabled: true
    interval_minutes: 180   # every 3 h — aligns with ICON-seamless update cadence
    horizon_hours: 30       # covers the next ~30 h where forecast freshness is most important
    config:
      # Commercial API key from open-meteo.com — enables the customer endpoint
      # (no rate limits). Also used automatically by the wind forecast grid collector.
      # Remove or leave blank to use the free public endpoint.
      api_key: ""

  - name: "open-meteo"
    enabled: true
    interval_minutes: 1440  # once per day — extended window changes slowly
    horizon_hours: 120      # full 5-day horizon
    config:
      api_key: ""  # shared with open-meteo-short — set in one place, applies to both

# Weather Data Collectors
collectors:
  - name: "meteoswiss"
    enabled: true
    interval_minutes: 10
    config:
      # MeteoSwiss free public GeoJSON API — one endpoint per observation type.
      # These defaults point to the official data.geo.admin.ch URLs.
      # You can override individual endpoints here if MeteoSwiss changes their URLs.
      endpoints:
        wind_speed:     "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-windgeschwindigkeit-kmh-10min/ch.meteoschweiz.messwerte-windgeschwindigkeit-kmh-10min_en.json"
        wind_gust:      "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-wind-boeenspitze-kmh-10min/ch.meteoschweiz.messwerte-wind-boeenspitze-kmh-10min_en.json"
        wind_direction: "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-windrichtung-10min/ch.meteoschweiz.messwerte-windrichtung-10min_en.json"
        temperature:    "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-lufttemperatur-10min/ch.meteoschweiz.messwerte-lufttemperatur-10min_en.json"
        humidity:       "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-luftfeuchtigkeit-10min/ch.meteoschweiz.messwerte-luftfeuchtigkeit-10min_en.json"
        pressure_qff:   "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-luftdruck-qff-10min/ch.meteoschweiz.messwerte-luftdruck-qff-10min_en.json"
        pressure_qfe:   "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-luftdruck-10min/ch.meteoschweiz.messwerte-luftdruck-10min_en.json"
        pressure_qnh:   "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-luftdruck-qnh-10min/ch.meteoschweiz.messwerte-luftdruck-qnh-10min_en.json"
        precipitation:  "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-niederschlag-10min/ch.meteoschweiz.messwerte-niederschlag-10min_en.json"

  - name: "holfuy"
    enabled: false
    interval_minutes: 5
    config:
      # API key from https://holfuy.com — passed as ?pw= query param.
      api_key: "your-holfuy-api-key"
      # station_ids: fetch only specific stations by their Holfuy integer IDs.
      # Set to "all" (or omit) to fetch every station associated with the key.
      # station_ids:
      #   - 101
      #   - 245

  - name: "slf"
    enabled: false
    interval_minutes: 30
    config:
      # Public SLF endpoints.
      stations_url: "https://public-meas-data.slf.ch/public/station-data/timepoint/WIND_MEAN/current/geojson"
      timeseries_url: "https://public-meas-data.slf.ch/public/station-data/timeseries/week/current/{network}/{code}"
      # Number of latest points kept per station per run.
      max_points: 6
      # Max concurrent station timeseries requests.
      concurrency: 20

  - name: "metar"
    enabled: false
    interval_minutes: 15
    config:
      metar_url: "https://aviationweather.gov/api/data/metar"
      stationinfo_url: "https://aviationweather.gov/api/data/stationinfo"
      icao_codes:
        - "LSZH"
        - "LSGG"
        - "LSZB"
        - "LSZR"
        - "LSMP"
        - "LSZA"
        - "LSGS"
        - "LSGL"
        - "LSGC"

  - name: "windline"
    enabled: false
    interval_minutes: 10
    config:
      data_url: "https://m.windline.ch/sensorAjaxData.php"
      # Windline payload values are treated as m/s and converted to km/h.
      # Set to "kmh" if Windline account/view is configured in km/h already.
      speed_unit: "mps"
      concurrency: 8
      stations:
        - id: "6200"
          name: "Amisbuehl"
        - id: "4104"
          name: "Grindelwald First"
        - id: "6679"
          name: "Hohwald"
        - id: "6116"
          name: "Lehn"
        - id: "4109"
          name: "Niederhorn"
        - id: "4096"
          name: "Niederhuenigen"

  - name: "ecowitt"
    enabled: false
    interval_minutes: 5
    config:
      # Each station entry has its own Ecowitt credentials (keys are per-account).
      # Get application_key and api_key from https://www.ecowitt.net/user/index → API
      stations:
        - application_key: "your-ecowitt-application-key"
          api_key: "your-ecowitt-device-api-key"
          mac: "AA:BB:CC:DD:EE:FF"  # gateway MAC address (from device settings)
          station_name: "My Weather Station"
          latitude: 46.6863
          longitude: 7.8632
          elevation: 600
        # Additional community stations:
        # - application_key: "..."
        #   api_key: "..."
        #   mac: "..."
        #   station_name: "Pilot Name / Site"
        #   latitude: ...
        #   longitude: ...
        #   elevation: ...

# SQLite Database (rule sets, launch sites, future user data)
database:
  path: "/app/data/lenticularis.db"

# Social OAuth (Google and Facebook login)
# Obtain credentials from Google Cloud Console and Meta for Developers.
# Redirect URIs to register:
#   https://your-domain.com/api/auth/google/callback
#   https://your-domain.com/api/auth/facebook/callback
oauth:
  # Public base URL of this instance — required when running behind a reverse proxy.
  # Must exactly match the domain you registered as the redirect URI in Google/Meta.
  base_url: "https://your-domain.com"
  google:
    enabled: false
    client_id: "your-google-client-id.apps.googleusercontent.com"
    client_secret: "your-google-client-secret"
  facebook:
    enabled: false
    client_id: "your-facebook-app-id"
    client_secret: "your-facebook-app-secret"

# Authentication
auth:
  jwt_secret: "change-me-in-production-use-openssl-rand-hex-32"
  jwt_algorithm: "HS256"
  access_token_expire_minutes: 60
  refresh_token_expire_days: 30

# Logging
logging:
  level: "INFO"   # DEBUG | INFO | WARNING | ERROR
  format: "text"
  file: "/app/logs/lenticularis.log"

# Station deduplication
# Two stations whose GPS coordinates are closer than distance_m metres are merged
# automatically into a single virtual station.  The highest-priority network wins
# (priority: meteoswiss > slf > metar > holfuy > windline > ecowitt > wunderground).
# Additional pairs can be added manually in the admin panel (Admin > Station Dedup).
station_dedup:
  distance_m: 50

# API Server
api:
  host: "0.0.0.0"
  port: 8000
  reload: false   # Set true only in local dev (not in Docker)

# Ollama AI assistant (optional — powers "Text Creation with AI" in the rule editor)
# When running the backend inside Docker, use host.docker.internal instead of localhost.
ollama:
  enabled: true
  url: "http://host.docker.internal:11434"   # or http://localhost:11434 outside Docker
  model: "qwen2.5:3b"
  timeout_seconds: 60